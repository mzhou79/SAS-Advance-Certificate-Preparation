/* Lab 4 - full join + coalesce, since either side may lack a match */
proc sql;
create table work.q4 as
select distinct
       coalesce(c.make, r.make) as make,
       coalesce(c.type, r.type) as type,
       r.rebate
from work.cars as c
full join work.rebate as r
on c.make = r.make and c.type = r.type;
quit;

/* Lab 5 */
proc sql;
create table work.q5 as
select *, case
   when height <= 170 then "Low"
   when height > 170 and height < 181 then "Middle"
   when height >= 181 then "High"
end as HLM
from work.lab5;
quit;

/* Lab 6 */
proc sql;
create table work.q6 as
select did, avg(salary) as avgsalary
from work.lab6
group by did
having avgsalary > 5000
order by avgsalary desc;
quit;

/* Lab 7 */
proc sql;
create table work.q7 as
select did, avg(salary) as avgsalary
from work.lab7
group by did
having avgsalary >= (select median(salary) from work.lab7);
quit;

/* Lab 8 - debug practice
   Bug 1 (getolder): parameter is "n" but code references "&nn" - typo.
   Fix: where age > &n;
   Bug 2 (checkage): "&age" is never a macro variable - age only exists as
   a DATA STEP variable inside the data step, invisible to %put outside it.
   There's no clean fix without passing the cutoff in as a real macro
   parameter - the lesson is that a data step variable and a macro
   variable are never the same thing, no matter how similar the name looks. */

%macro getolder(dsn, n);
  proc sql;
    create table work.older_group as
    select * from &dsn
    where age > &n;
  quit;
%mend;
%getolder(work.lab8a, 30)

